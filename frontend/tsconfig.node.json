{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "ESNext"
    ],
    "types": [
      "node"
    ],
    "skipLibCheck": false,
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.node.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts",
    "postcss.config.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".vite"
  ]
}
