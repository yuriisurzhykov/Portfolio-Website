{
  "name": "@portfolio/backend",
  "version": "0.0.1",
  "private": true,
  "description": "Server-only code for the portfolio site: Prisma schema/client, auth, business-logic services. Consumed by web/ (Next.js) as an npm workspace package — not a separate deployable process, see web/README.md for the single-process decision.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./edge": "./src/edge.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev && prisma generate",
    "create-admin": "tsx scripts/create-admin.ts",
    "test": "npm run test:migrate && vitest run",
    "test:watch": "vitest",
    "test:migrate": "dotenv -e .env.test -- prisma migrate deploy"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.45.0",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
