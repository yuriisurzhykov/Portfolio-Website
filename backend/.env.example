# Copy to backend/.env for local development (never commit the real .env —
# it's covered by the repo-root .gitignore's "*.env" style rule already).
# web/next.config.ts loads this same file explicitly, so there is exactly
# one place DATABASE_URL/JWT secrets live for local dev — see backend/README.md.

# Matches docker-compose.yml at the repo root.
DATABASE_URL="postgresql://portfolio:portfolio_dev_only@127.0.0.1:5432/portfolio"

# Generate real values with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me"
