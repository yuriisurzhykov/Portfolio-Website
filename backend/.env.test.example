# Copy to backend/.env.test for running tests locally (`npm test`).
# A SEPARATE database from backend/.env's DATABASE_URL, on purpose — tests
# create/delete real rows (users, sessions); running them against the same
# database as local manual dev/testing would wipe your own data.
DATABASE_URL="postgresql://portfolio:portfolio_dev_only@127.0.0.1:5432/portfolio_test"

JWT_ACCESS_SECRET="test-access-secret-not-for-real-use"
JWT_REFRESH_SECRET="test-refresh-secret-not-for-real-use"
